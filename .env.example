# Nano CMS — environment variables
# Copy this file to `.env` and edit. The `.env` file is gitignored.

# ---------- App ----------
APP_NAME="Nano CMS"
APP_URL=""
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR

# Set when Nano is mounted at a subdirectory (e.g. http://example.com/nano/)
# Leave empty to autodetect from SCRIPT_NAME.
# APP_BASE_PATH=/nano

# ---------- Database ----------
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=nano
DB_USERNAME=root
DB_PASSWORD=""

# ---------- First-run install ----------
# Used the FIRST time Nano boots against this database. The installer creates
# the DB (if missing), runs migrations, syncs pages from site.json, and creates
# this admin user. Once a user exists, these are ignored — feel free to remove
# them after first login.
INITIAL_USER_EMAIL=""
INITIAL_USER_PASSWORD=""
INITIAL_USER_NAME="Admin"

# ---------- Session ----------
SESSION_NAME=nano_session
SESSION_LIFETIME=604800

# ---------- Admin ----------
# ADMIN_PREFIX=/admin

# ---------- SMTP (optional) ----------
# Used for outgoing email (password resets, etc).
# When empty, Nano falls back to PHP's mail() which only works on servers with sendmail configured.
# Port 465 = implicit SSL, port 587 = STARTTLS.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Nano CMS <noreply@example.com>"
