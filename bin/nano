#!/usr/bin/env php
<?php

declare(strict_types=1);

if (PHP_SAPI !== 'cli') {
    fwrite(STDERR, "This script must be run from the command line.\n");
    exit(1);
}

$rootPath = dirname(__DIR__);
require_once $rootPath . '/core/Bootstrap.php';

$args = array_slice($argv, 1);
$command = $args[0] ?? 'help';
$rest = array_slice($args, 1);

// Parse --key=value flags from $rest
$flags = [];
$positional = [];
foreach ($rest as $arg) {
    if (str_starts_with($arg, '--')) {
        $eq = strpos($arg, '=');
        if ($eq === false) {
            $flags[substr($arg, 2)] = true;
        } else {
            $flags[substr($arg, 2, $eq - 2)] = substr($arg, $eq + 1);
        }
    } else {
        $positional[] = $arg;
    }
}

/**
 * Boot the app, handling SetupException so install-related commands keep working.
 */
$bootForInstall = function () use ($rootPath) {
    Nano\Autoloader::register($rootPath);
    require_once $rootPath . '/core/helpers.php';
    Nano\Env::load($rootPath . '/.env');
    $config = new Nano\Config($rootPath);

    // Ensure DB exists, then construct App with relaxed auto-install
    Nano\Installer::ensureDatabase($config->get('database'));

    // We bypass App::register's auto-install gate by booting after DB exists.
    // But App::register still runs the gate — to allow `install` to run when
    // INITIAL_USER_* are missing, we provide a temporary env so the gate passes,
    // then rely on the install command to create the user explicitly.
    return null;
};

$commands = [
    'help' => function () {
        echo "Nano CMS — CLI\n";
        echo "Usage: bin/nano <command> [args] [--flags]\n\n";
        echo "Setup:\n";
        echo "  install                              Run a complete install (DB + migrations + user)\n";
        echo "    --email=<email>                    Override INITIAL_USER_EMAIL from .env\n";
        echo "    --password=<password>              Override INITIAL_USER_PASSWORD from .env\n";
        echo "    --name=<name>                      Override INITIAL_USER_NAME from .env\n";
        echo "  migrate                              Run pending migrations\n";
        echo "  migrate:status                       Show pending migrations\n";
        echo "  user:create <email> <pwd> <name>     Create a new admin user\n";
        echo "  page:sync                            Create page records from site.json\n";
        echo "  files:init                           Copy .htaccess.example, robots.txt.example into place\n";
        echo "  schema:validate                      Validate site.json structure\n";
        echo "  serve [port]                         Start built-in PHP server\n";
        echo "  cleanup:login-attempts               Drop login_attempts older than --days=30\n";
        echo "\nContent (items — posts, services, etc.):\n";
        echo "  item:types                           List item types defined in site.json\n";
        echo "  item:schema <type>                   Show field schema for a type\n";
        echo "  item:list <type>                     List items (filter --status, --search, --limit)\n";
        echo "  item:get <type> <slug-or-id>         Get a single item as JSON\n";
        echo "  item:create <type> --json=<JSON>     Create a new item (JSON or --json-stdin)\n";
        echo "  item:update <type> <slug> --json=… Partial update (merges into fields)\n";
        echo "  item:publish <type> <slug>           Set status=published, stamp published_at\n";
        echo "  item:unpublish <type> <slug>         Set status=draft\n";
        echo "  item:delete <type> <slug> --confirm  Delete an item (destructive)\n";
        echo "\nContent (pages — singular page entities like home, about):\n";
        echo "  page:list                            List configured pages\n";
        echo "  page:schema <key>                    Show field schema for a page\n";
        echo "  page:get <key>                       Get current page data as JSON\n";
        echo "  page:update <key> --json=<JSON>      Update page fields (merges)\n";
        echo "\nCommon flags for content commands:\n";
        echo "  --format=json                        Machine-readable output (default: text)\n";
        echo "  --dry-run                            Validate without saving (create/update only)\n";
        echo "  --json-stdin                         Read --json payload from stdin (avoids quoting hell)\n";
        echo "\n";
    },

    'install' => function () use ($rootPath, $flags) {
        Nano\Autoloader::register($rootPath);
        require_once $rootPath . '/core/helpers.php';
        Nano\Env::load($rootPath . '/.env');

        $config = new Nano\Config($rootPath);
        $dbConfig = $config->get('database');

        echo "Nano CMS — Install\n";
        echo "──────────────────\n\n";

        echo "1. Database `{$dbConfig['database']}` … ";
        try {
            Nano\Installer::ensureDatabase($dbConfig);
            echo "OK\n";
        } catch (\Throwable $e) {
            echo "FAIL\n";
            fwrite(STDERR, "   " . $e->getMessage() . "\n");
            fwrite(STDERR, "   Check DB_HOST, DB_USERNAME, DB_PASSWORD in .env\n");
            exit(1);
        }

        // Construct a minimal App (no session/auth — those are web-only)
        $app = new Nano\App($config);
        $app->db = new Nano\Database($dbConfig);

        // Build user override from flags (override .env values when provided)
        $userOverride = [];
        if (isset($flags['email']))    $userOverride['email']    = (string) $flags['email'];
        if (isset($flags['password'])) $userOverride['password'] = (string) $flags['password'];
        if (isset($flags['name']))     $userOverride['name']     = (string) $flags['name'];

        try {
            $report = Nano\Installer::install($app, $userOverride);
        } catch (\Throwable $e) {
            fwrite(STDERR, "Install failed: " . $e->getMessage() . "\n");
            exit(1);
        }

        $migCount = count($report['migrations']);
        echo "2. Migrations: " . ($migCount === 0 ? 'up to date' : "{$migCount} applied") . "\n";
        foreach ($report['migrations'] as $m) {
            echo "   + {$m}\n";
        }

        $copied = $report['project_files_copied'] ?? [];
        if ($copied !== []) {
            echo "   Project files initialized:\n";
            foreach ($copied as $f) {
                echo "   + {$f}\n";
            }
        }

        echo "3. Pages: " . ($report['pages_synced'] === 0 ? 'already synced' : "{$report['pages_synced']} added") . "\n";

        if ($report['user_created'] !== null) {
            echo "4. Initial user: {$report['user_created']}\n";
            echo "\n✓ Installed.\n";
            echo "  → Open /admin/login and sign in.\n";
            return;
        }

        if ($report['user_skipped_reason'] === 'users_already_exist') {
            echo "4. Initial user: skipped (database already has users)\n";
            echo "\n✓ Already installed.\n";
            return;
        }

        echo "4. Initial user: skipped (no credentials provided)\n";
        echo "\n";
        echo "  → Add INITIAL_USER_EMAIL and INITIAL_USER_PASSWORD to .env, then re-run.\n";
        echo "  → Or:  ./bin/nano install --email=you@example.com --password=secret --name=\"Your Name\"\n";
        exit(2);
    },

    'migrate' => function () use ($rootPath) {
        $app = Nano\Bootstrap::boot($rootPath);
        $migrator = new Nano\Migrator($app->db, $app->config->path('migrations'));
        $applied = $migrator->migrate();
        if ($applied === []) {
            echo "Nothing to migrate.\n";
            return;
        }
        foreach ($applied as $name) {
            echo "Applied: {$name}\n";
        }
    },

    'migrate:status' => function () use ($rootPath) {
        $app = Nano\Bootstrap::boot($rootPath);
        $migrator = new Nano\Migrator($app->db, $app->config->path('migrations'));
        $pending = $migrator->pending();
        if ($pending === []) {
            echo "All migrations are up to date.\n";
            return;
        }
        echo "Pending migrations:\n";
        foreach ($pending as $file) {
            echo "  - " . basename($file) . "\n";
        }
    },

    'user:create' => function () use ($rootPath, $positional) {
        $app = Nano\Bootstrap::boot($rootPath);
        [$email, $password, $name] = [$positional[0] ?? null, $positional[1] ?? null, $positional[2] ?? null];
        if (!$email || !$password || !$name) {
            fwrite(STDERR, "Usage: bin/nano user:create <email> <password> <name>\n");
            exit(1);
        }
        $existing = Nano\Models\User::findByEmail($email);
        if ($existing !== null) {
            fwrite(STDERR, "User already exists: {$email}\n");
            exit(1);
        }
        $user = Nano\Models\User::create($email, $password, $name);
        echo "Created user #{$user->id}: {$user->email}\n";
    },

    'files:init' => function () use ($rootPath) {
        // Copy `.example` templates into their live counterparts. Useful when
        // a Nano update ships a new example file (e.g. robots.txt added later)
        // and existing installs need to pick it up. Existing live files are
        // preserved — this command never overwrites.
        $app = Nano\Bootstrap::boot($rootPath);
        $created = Nano\Installer::ensureProjectFiles($app);
        if ($created === []) {
            echo "All project files already in place — nothing to copy.\n";
            return;
        }
        echo "Copied:\n";
        foreach ($created as $f) {
            echo "  + {$f}\n";
        }
    },

    'page:sync' => function () use ($rootPath) {
        $app = Nano\Bootstrap::boot($rootPath);
        $pages = $app->config->pages();
        $created = 0;
        $updated = 0;
        foreach ($pages as $key => $page) {
            $title = (string) ($page['label'] ?? $key);
            $existing = Nano\Models\Page::findByKey((string) $key);
            if ($existing === null) {
                Nano\Models\Page::upsert((string) $key, $title, []);
                $created++;
            } else {
                if ($existing->title !== $title) {
                    Nano\Models\Page::upsert((string) $key, $title, $existing->fields);
                    $updated++;
                }
            }
        }
        echo "Pages synced. Created: {$created}, updated: {$updated}.\n";
    },

    'schema:validate' => function () use ($rootPath) {
        $app = Nano\Bootstrap::boot($rootPath);
        $issues = [];
        $site = $app->config->site();

        if (!isset($site['pages']) || !is_array($site['pages'])) {
            $issues[] = 'site.json is missing "pages" object.';
        }
        if (!isset($site['item_types']) || !is_array($site['item_types'])) {
            $issues[] = 'site.json is missing "item_types" object.';
        }
        if (!isset($site['taxonomies'])) {
            $issues[] = 'site.json is missing "taxonomies" object (use {} if none).';
        }

        foreach (($site['pages'] ?? []) as $key => $page) {
            if (!isset($page['template'])) {
                $issues[] = "Page \"{$key}\" is missing a template.";
            }
        }
        foreach (($site['item_types'] ?? []) as $type => $def) {
            if (!isset($def['template'])) {
                $issues[] = "Item type \"{$type}\" is missing a template.";
            }
            if (!isset($def['slug'])) {
                $issues[] = "Item type \"{$type}\" is missing a slug.";
            }
        }
        foreach (($site['taxonomies'] ?? []) as $tax => $def) {
            if (!isset($def['template'])) {
                $issues[] = "Taxonomy \"{$tax}\" is missing a template.";
            }
        }
        foreach (($site['forms'] ?? []) as $form => $def) {
            if (!isset($def['fields']) || !is_array($def['fields']) || $def['fields'] === []) {
                $issues[] = "Form \"{$form}\" is missing a non-empty 'fields' array.";
            }
            foreach ((array)($def['fields'] ?? []) as $i => $f) {
                if (!isset($f['name'])) {
                    $issues[] = "Form \"{$form}\" field #{$i} is missing 'name'.";
                }
            }
        }
        foreach (($site['options'] ?? []) as $opt => $def) {
            if (!isset($def['fields']) || !is_array($def['fields'])) {
                $issues[] = "Options page \"{$opt}\" is missing 'fields' array.";
            }
        }

        if ($issues === []) {
            echo "site.json is valid.\n";
        } else {
            echo "Issues found in site.json:\n";
            foreach ($issues as $i) {
                echo "  - {$i}\n";
            }
            exit(1);
        }
    },

    'serve' => function () use ($rootPath, $positional) {
        $port = (int) ($positional[0] ?? 8080);
        echo "Nano CMS serving on http://localhost:{$port}\n";
        passthru(sprintf(
            'php -S localhost:%d -t %s %s',
            $port,
            escapeshellarg($rootPath),
            escapeshellarg($rootPath . '/index.php')
        ));
    },

    /*
     * Drop login_attempts rows older than --days (default 30).
     *
     * Why this exists: the rate-limiter (LoginAttemptService) keeps
     * inserting rows but never cleans up — the throttle queries always
     * filter by time window so leaving old rows around doesn't break
     * anything, just wastes disk. Run this manually via SSH every now
     * and then, or schedule via cron in /etc/crontab if you prefer:
     *   0 3 * * *  cd /var/www/<project> && php bin/nano cleanup:login-attempts
     *
     * Idempotent: running it twice in a row deletes nothing the second
     * time.
     */
    'cleanup:login-attempts' => function () use ($rootPath, $flags) {
        $app = Nano\Bootstrap::boot($rootPath);
        $days = isset($flags['days']) ? max(1, (int) $flags['days']) : 30;

        $service = new Nano\Services\LoginAttemptService();
        $deleted = $service->cleanup($days);

        echo "Removed {$deleted} login_attempts row" . ($deleted === 1 ? '' : 's')
           . " older than {$days} day" . ($days === 1 ? '' : 's') . ".\n";
    },

    // ─────────────────────────────────────────────────────────────────────
    // Content commands (item:* and page:*)
    //
    // These dispatch to Nano\Commands\Content. The wiring here is intentionally
    // thin — each closure boots the app, gathers args/flags, calls the static
    // method, and returns. All real logic (schema resolution, validation,
    // JSON formatting) lives in core/Commands/Content.php so it's testable
    // and reusable from non-CLI contexts.
    //
    // Convention for input:
    //   --json='{...}'        → JSON inline (escape hell on the shell)
    //   --json-stdin          → read JSON payload from stdin (preferred for
    //                           anything non-trivial; avoids escaping issues)
    //
    // Convention for output:
    //   default               → human-friendly text on stdout, errors on stderr
    //   --format=json         → single JSON line on stdout, structured errors
    //                           ({"ok": false, ...}) instead of non-zero exit
    // ─────────────────────────────────────────────────────────────────────

    'item:types' => function () use ($rootPath, $flags) {
        $app = Nano\Bootstrap::boot($rootPath);
        Nano\Commands\Content::itemTypes($app, contentFormat($flags));
    },

    'item:schema' => function () use ($rootPath, $positional, $flags) {
        $app = Nano\Bootstrap::boot($rootPath);
        $type = $positional[0] ?? '';
        if ($type === '') { fwrite(STDERR, "Usage: bin/nano item:schema <type>\n"); exit(1); }
        Nano\Commands\Content::itemSchema($app, $type, contentFormat($flags));
    },

    'item:list' => function () use ($rootPath, $positional, $flags) {
        $app = Nano\Bootstrap::boot($rootPath);
        $type = $positional[0] ?? '';
        if ($type === '') { fwrite(STDERR, "Usage: bin/nano item:list <type>\n"); exit(1); }
        $status = isset($flags['status']) ? (string) $flags['status'] : null;
        if ($status === 'all') $status = null; // model API treats null as no-filter
        $search = isset($flags['search']) ? (string) $flags['search'] : null;
        $limit  = isset($flags['limit'])  ? (int) $flags['limit'] : 100;
        Nano\Commands\Content::itemList($app, $type, $status, $search, $limit, contentFormat($flags));
    },

    'item:get' => function () use ($rootPath, $positional, $flags) {
        $app = Nano\Bootstrap::boot($rootPath);
        $type = $positional[0] ?? '';
        $slug = $positional[1] ?? '';
        if ($type === '' || $slug === '') {
            fwrite(STDERR, "Usage: bin/nano item:get <type> <slug-or-id>\n"); exit(1);
        }
        Nano\Commands\Content::itemGet($app, $type, $slug, contentFormat($flags));
    },

    'item:create' => function () use ($rootPath, $positional, $flags) {
        $app = Nano\Bootstrap::boot($rootPath);
        $type = $positional[0] ?? '';
        if ($type === '') { fwrite(STDERR, "Usage: bin/nano item:create <type> --json=<JSON>\n"); exit(1); }
        $json = readJsonInput($flags);
        if ($json === null) { fwrite(STDERR, "Pass --json='{...}' or --json-stdin\n"); exit(1); }
        Nano\Commands\Content::itemCreate($app, $type, $json, !empty($flags['dry-run']), contentFormat($flags));
    },

    'item:update' => function () use ($rootPath, $positional, $flags) {
        $app = Nano\Bootstrap::boot($rootPath);
        $type = $positional[0] ?? '';
        $slug = $positional[1] ?? '';
        if ($type === '' || $slug === '') {
            fwrite(STDERR, "Usage: bin/nano item:update <type> <slug-or-id> --json=<JSON>\n"); exit(1);
        }
        $json = readJsonInput($flags);
        if ($json === null) { fwrite(STDERR, "Pass --json='{...}' or --json-stdin\n"); exit(1); }
        Nano\Commands\Content::itemUpdate($app, $type, $slug, $json, !empty($flags['dry-run']), contentFormat($flags));
    },

    'item:publish' => function () use ($rootPath, $positional, $flags) {
        $app = Nano\Bootstrap::boot($rootPath);
        $type = $positional[0] ?? '';
        $slug = $positional[1] ?? '';
        if ($type === '' || $slug === '') {
            fwrite(STDERR, "Usage: bin/nano item:publish <type> <slug-or-id>\n"); exit(1);
        }
        Nano\Commands\Content::itemPublish($app, $type, $slug, contentFormat($flags));
    },

    'item:unpublish' => function () use ($rootPath, $positional, $flags) {
        $app = Nano\Bootstrap::boot($rootPath);
        $type = $positional[0] ?? '';
        $slug = $positional[1] ?? '';
        if ($type === '' || $slug === '') {
            fwrite(STDERR, "Usage: bin/nano item:unpublish <type> <slug-or-id>\n"); exit(1);
        }
        Nano\Commands\Content::itemUnpublish($app, $type, $slug, contentFormat($flags));
    },

    'item:delete' => function () use ($rootPath, $positional, $flags) {
        $app = Nano\Bootstrap::boot($rootPath);
        $type = $positional[0] ?? '';
        $slug = $positional[1] ?? '';
        if ($type === '' || $slug === '') {
            fwrite(STDERR, "Usage: bin/nano item:delete <type> <slug-or-id> --confirm\n"); exit(1);
        }
        Nano\Commands\Content::itemDelete($app, $type, $slug, !empty($flags['confirm']), contentFormat($flags));
    },

    'page:list' => function () use ($rootPath, $flags) {
        $app = Nano\Bootstrap::boot($rootPath);
        Nano\Commands\Content::pageList($app, contentFormat($flags));
    },

    'page:schema' => function () use ($rootPath, $positional, $flags) {
        $app = Nano\Bootstrap::boot($rootPath);
        $key = $positional[0] ?? '';
        if ($key === '') { fwrite(STDERR, "Usage: bin/nano page:schema <key>\n"); exit(1); }
        Nano\Commands\Content::pageSchema($app, $key, contentFormat($flags));
    },

    'page:get' => function () use ($rootPath, $positional, $flags) {
        $app = Nano\Bootstrap::boot($rootPath);
        $key = $positional[0] ?? '';
        if ($key === '') { fwrite(STDERR, "Usage: bin/nano page:get <key>\n"); exit(1); }
        Nano\Commands\Content::pageGet($app, $key, contentFormat($flags));
    },

    'page:update' => function () use ($rootPath, $positional, $flags) {
        $app = Nano\Bootstrap::boot($rootPath);
        $key = $positional[0] ?? '';
        if ($key === '') {
            fwrite(STDERR, "Usage: bin/nano page:update <key> --json=<JSON>\n"); exit(1);
        }
        $json = readJsonInput($flags);
        if ($json === null) { fwrite(STDERR, "Pass --json='{...}' or --json-stdin\n"); exit(1); }
        Nano\Commands\Content::pageUpdate($app, $key, $json, !empty($flags['dry-run']), contentFormat($flags));
    },
];

/**
 * Resolve --format flag for content commands. Falls back to 'text'.
 * Lives outside the $commands array so all closures can use it without
 * each having to peek at $flags themselves.
 */
function contentFormat(array $flags): string
{
    $f = (string) ($flags['format'] ?? 'text');
    return in_array($f, ['text', 'json'], true) ? $f : 'text';
}

/**
 * Read a JSON payload from --json='...' or stdin (--json-stdin).
 * Returns the raw JSON string (NOT decoded) so the Content class can do
 * its own decoding-with-error-message. Returns null when neither source
 * was provided — callers should error.
 *
 * Stdin mode exists because shell-escaping nontrivial JSON payloads is
 * miserable (newlines, quotes, special chars). The skill almost always
 * uses stdin; humans typing a quick test usually use --json='...'.
 */
function readJsonInput(array $flags): ?string
{
    if (!empty($flags['json-stdin'])) {
        $data = stream_get_contents(STDIN);
        return $data === false ? null : $data;
    }
    if (isset($flags['json']) && is_string($flags['json'])) {
        return $flags['json'];
    }
    return null;
}

if (!isset($commands[$command])) {
    fwrite(STDERR, "Unknown command: {$command}\n");
    fwrite(STDERR, "Run 'bin/nano help' for available commands.\n");
    exit(1);
}

try {
    $commands[$command]();
} catch (Nano\SetupException $e) {
    fwrite(STDERR, "Setup error: " . $e->getMessage() . "\n");
    fwrite(STDERR, "Run: ./bin/nano install\n");
    exit(2);
}
