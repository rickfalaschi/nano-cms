/storage/uploads/*
!/storage/uploads/.gitkeep
/storage/cache/*
!/storage/cache/.gitkeep
/storage/logs/*
!/storage/logs/.gitkeep

# Theme — project-specific, not part of Nano core.
# Each project clones its own theme repo into `theme/`:
#   git clone https://github.com/your-org/your-theme.git theme
/theme/

# Per-project files — Nano ships `.example` versions; live versions are
# gitignored so projects can customize them (custom redirects, security
# headers, crawler rules, server-specific tuning) without future Nano
# updates overwriting their changes. The `.example` files (.htaccess.example,
# nginx.conf.example, robots.txt.example) remain versioned as templates.
/.htaccess
/nginx.conf
/robots.txt

# Environment — local secrets, never commit
.env
.env.local
/config/env.local.php

# Deploy config — SSH credentials and DB password for remote.
# Created by nano-ssh-deploy / nano-ssh-download / nano-ssh-content.
/.deploy/

# Editor / tooling per-machine settings
.DS_Store
.idea/
.vscode/
.claude/
*.log
