/vendor/
/storage/uploads/*
!/storage/uploads/.gitkeep
/storage/cache/*
!/storage/cache/.gitkeep
/storage/logs/*
!/storage/logs/.gitkeep

# Theme — project-specific, not part of Nano core.
# Each project clones its own theme repo into `theme/`:
#   git clone https://github.com/your-org/your-theme.git theme
/theme/

# Per-project files — Nano ships `.example` versions, the Installer copies
# them into place, and from there they belong to the project. Editing them
# (custom redirects, security headers, robots rules, etc.) is expected and
# should NOT be overwritten by future updates of Nano core.
/.htaccess
/robots.txt

# Environment — local secrets, never commit
.env
.env.local
/config/env.local.php

.DS_Store
.idea/
.vscode/
*.log
composer.lock
