/vendor/
/storage/uploads/*
!/storage/uploads/.gitkeep
/storage/cache/*
!/storage/cache/.gitkeep
/storage/logs/*
!/storage/logs/.gitkeep

# Theme — project-specific, not part of Nano core.
# Each project drops its own theme into `theme/`. We keep the directory
# committed (via .gitkeep) so the layout is obvious to anyone cloning,
# but no theme contents are tracked.
/theme/*
!/theme/.gitkeep

# Environment — local secrets, never commit
.env
.env.local
/config/env.local.php

.DS_Store
.idea/
.vscode/
*.log
composer.lock
